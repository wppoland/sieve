# Files excluded from the wp.org build. NOTE: /vendor is intentionally NOT
# ignored — after `composer install --no-dev` it holds only runtime deps
# (wppoland/storefront-kit + the Composer autoloader), which MUST ship.
/.git
/.github
/.gitignore
/.distignore
/.wp-env.json
/.wp-env.override.json
/node_modules
/tests
/scripts
/docs
/composer.json
/composer.lock
/package.json
/package-lock.json
/phpcs.xml.dist
/phpstan.neon.dist
/phpstan-baseline.neon
/playwright.config.ts
/tsconfig.json
/vite.config.ts
/SPEC.md
/README.md
/.DS_Store

.DS_Store
/assets
/SUBMISSION.md
/test-results
/playwright-report
/.playwright-mcp
