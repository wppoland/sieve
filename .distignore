# Files excluded from the wp.org build. The storefront-kit runtime is bundled
# in /lib/storefront-kit (de-vendored), loaded via the PSR-4 fallback in
# autoload.php, so /vendor (Composer + dev deps) is excluded.
/.git
/.github
/.gitignore
/.distignore
/.wp-env.json
/.wp-env.override.json
/node_modules
/vendor
# /resources ships: it holds the human-readable source (index.tsx etc.) for the
# minified build/ bundles, which wp.org review requires for compiled code.
/tests
/scripts
/docs
/composer.json
/composer.lock
/package.json
/package-lock.json
/phpcs.xml.dist
/phpstan.neon.dist
/phpstan-baseline.neon
/playwright.config.ts
/tsconfig.json
/vite.config.ts
/SPEC.md
/README.md
/.DS_Store

.DS_Store
/assets
/SUBMISSION.md
/.wordpress-org
/test-results
/playwright-report
/.playwright-mcp

# editor backups (never ship / never a badly_named_files reject)
*~
*.bak
