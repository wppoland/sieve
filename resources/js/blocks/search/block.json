{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "sieve/search",
  "version": "0.4.0",
  "title": "Sieve Search",
  "category": "woocommerce",
  "icon": "search",
  "description": "Predictive product search with an instant, accessible typeahead dropdown.",
  "keywords": ["search", "typeahead", "autocomplete", "product", "woocommerce"],
  "textdomain": "sieve",
  "attributes": {
    "placeholder": { "type": "string", "default": "" },
    "button": { "type": "boolean", "default": true },
    "button_text": { "type": "string", "default": "" },
    "limit": { "type": "number", "default": 6 },
    "min_chars": { "type": "number", "default": 2 },
    "in_stock_only": { "type": "boolean", "default": true }
  },
  "supports": {
    "html": false,
    "align": ["wide"]
  },
  "editorScript": "file:./index.js"
}
