#. Plugin Name of the plugin
#: sieve.php
msgid "Sieve - Faceted Filter for WooCommerce"
msgstr "Sieve – Facettenfilter für WooCommerce"

#. Plugin URI of the plugin
#: sieve.php
msgid "https://plogins.com/sieve/"
msgstr "https://plogins.com/sieve/"

#. Description of the plugin
#: sieve.php
msgid ""
"Fast, accessible faceted filtering for WooCommerce and WordPress. Beautiful "
"facet widgets, AJAX filtering with no page reload, a mobile filter drawer, "
"and Core Web Vitals by design."
msgstr ""
"Schnelle, zugängliche Facettenfilterung für WooCommerce und WordPress. "
"Wunderschöne Facetten-Widgets, AJAX-Filterung ohne Neuladen der Seite, eine "
"mobile Filterschublade und Core Web Vitals by Design."

#. Author of the plugin
#: sieve.php
msgid "WPPoland"
msgstr "WPPoland"

#. Author URI of the plugin
#: sieve.php
msgid "https://wppoland.com"
msgstr "https://wppoland.com"

