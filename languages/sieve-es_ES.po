#. Plugin Name of the plugin
#: sieve.php
msgid "Sieve - Faceted Filter for WooCommerce"
msgstr "Sieve - Filtro facetado para WooCommerce"

#. Plugin URI of the plugin
#: sieve.php
msgid "https://plogins.com/sieve/"
msgstr "https://plogins.com/sieve/"

#. Description of the plugin
#: sieve.php
msgid ""
"Fast, accessible faceted filtering for WooCommerce and WordPress. Beautiful "
"facet widgets, AJAX filtering with no page reload, a mobile filter drawer, "
"and Core Web Vitals by design."
msgstr ""
"Filtrado por facetas rápido y accesible para WooCommerce y WordPress. "
"Hermosos widgets de facetas, filtrado AJAX sin recarga de página, un cajón "
"de filtros móvil y Core Web Vitals por diseño."

#. Author of the plugin
#: sieve.php
msgid "WPPoland"
msgstr "WPPoland"

